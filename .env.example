FLASK_APP=wsgi.py
FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///priorityshift.db

# --- Optional: real notification delivery (all off/no-op unless set) ---
NOTIFICATION_DELIVERY_ENABLED=false
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=priorityshift@example.com
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# --- Optional: generic OIDC SSO (login page stays password-only until set) ---
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=
OIDC_PROVIDER_NAME=SSO
